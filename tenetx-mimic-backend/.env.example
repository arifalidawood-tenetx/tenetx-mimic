# --- Auth / Firebase Admin ---------------------------------------------
# `firebase login:ci` refresh token (Coolify env FIREBASE_REFRESH_TOKEN).
# Required: without it, Firebase Admin SDK never initializes, the auth
# middleware rejects ALL requests, and getMimicIdpConnection() always
# returns null (no per-tester IdP override from Firestore).
FIREBASE_REFRESH_TOKEN=

# HMAC secret used to sign/verify short-lived SAML status tokens
# (statusToken.ts). Falls back to a hardcoded insecure dev-only secret
# with a loud warning when unset -- forgeable, so always set in any
# real deployment.
MIMIC_STATUS_SECRET=

# --- Server ---------------------------------------------------------------
# Listen port. Defaults to 3000.
PORT=3000

# Listen host. Defaults to 0.0.0.0.
HOST=0.0.0.0

# CORS allowlist origin for the SPA calling this backend.
# Defaults to https://tenetx-mimic.web.app.
ALLOWED_ORIGIN=https://tenetx-mimic.web.app

# --- Real Keycloak IdP identity (fallback, used when RelayState carries no
# connectionDocId / Firestore per-tester lookup misses) --------------------
# Without these, the harness falls back to its synthetic default entity ID
# and every real login is rejected with an issuer mismatch.
MIMIC_IDP_ENTITY_ID=
MIMIC_IDP_SSO_URL=
MIMIC_IDP_CERT_FILE=

# --- Optional / dev overrides ----------------------------------------------
# Explicit python executable for shelling out to the SAML harness scripts.
# Auto-detected (product .venv, then `python`/`python3`) when unset.
MIMIC_PYTHON=

# Override the .captured/ SAMLResponse capture directory (mainly used by
# tests to isolate parallel runs). Defaults to <package-root>/.captured.
MIMIC_CAPTURED_DIR=
