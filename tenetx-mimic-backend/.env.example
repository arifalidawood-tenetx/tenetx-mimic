FIREBASE_REFRESH_TOKEN=
MIMIC_STATUS_SECRET=
ALLOWED_ORIGIN=
HOST=
PORT=

# Real Keycloak IdP identity for /saml/acs live validation (IdP-initiated POST
# carries no session/query state to source this from per-request, unlike
# /saml/login -- see index.ts's validateCapturedResponse). Without these, the
# harness falls back to its synthetic default entity ID and every real login
# is rejected with an issuer mismatch.
MIMIC_IDP_ENTITY_ID=
MIMIC_IDP_SSO_URL=
MIMIC_IDP_CERT_FILE=

# trace|debug|info|warn|error|fatal|silent - defaults to debug locally, info in production, silent in tests
LOG_LEVEL=

# development|production|test - controls default LOG_LEVEL and whether pino-pretty is used
NODE_ENV=

# set to 'false' to force JSON output even outside production
LOG_PRETTY=