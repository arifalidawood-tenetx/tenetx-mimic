# Firebase deploy cache
.firebase/
firebase-debug.log

# TEN-141 SAML harness: NEVER commit real captured SAMLResponses (signed token + PII).
# Only synthetic/redacted fixtures (e.g. harness/fixtures/synthetic-unsigned.xml) are safe.
harness/fixtures/*.captured.txt
harness/fixtures/*.captured.xml
harness/.captured/

# Python bytecode from the harness / its tests
__pycache__/
*.pyc
.pytest_cache/

# runners/ dev tooling: local Python venv + streamed dev-server logs (never commit)
runners/.venv/
runners/logs/

# tenetx-mimic-backend/ dev venv (bootstrapped by runners/run.ps1 for local `uvicorn` dev runs;
# separate from the Docker image's own venv, never commit)
tenetx-mimic-backend/.venv/

.omo
.omc