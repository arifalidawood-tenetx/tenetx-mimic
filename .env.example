# --- Firebase client SDK config (src/lib/firebaseClient.ts) ---------------
# Exposed to the browser via Vite's import.meta.env -- values from the
# Firebase console for the tenetx-qa-scores web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- SAML proxy backend / MCP public base -----------------------------------
# Base URL of the tenetx-mimic-backend deployment (TryItOutPage.tsx,
# SamlConfigPage.tsx). Also the public MCP base: agents connect at
# `{VITE_SAML_PROXY_URL}/mcp` (Streamable HTTP + Bearer PAT). Never `/mcp/mcp`.
# Empty string when unset -- the MCP page shows a config-missing warning.
VITE_SAML_PROXY_URL=

# --- Deployment / CI --------------------------------------------------------
# `firebase login:ci` token used by the seed-*-admin.ts scripts and
# verify-seed.ts to authenticate firebase-tools non-interactively.
FIREBASE_TOKEN=

# --- Backend runtime secrets (tenetx-mimic-backend) -------------------------
# HMAC secret signing the Try-It-Out status token (app/status_token.py).
# Falls back to an insecure dev-only constant if unset -- always set in any
# deployed environment.
MIMIC_STATUS_SECRET=
# Reserved for an upcoming OIDC client flow -- currently unreferenced in
# app/ code (verified via repo-wide grep). Keep set once that work lands;
# safe to leave blank until then.
OIDC_CLIENT_SECRET=

# --- Keycloak OIDC (client_credentials) -> GCP WIF subject-token mint -------
# app/gcp_credentials.py's _KeycloakSubjectTokenSupplier fetches a Keycloak
# access token via client_credentials, which google-auth exchanges at Google
# STS (below) for short-lived Google credentials. Keyless: no service-account
# key file, no long-lived FIREBASE_REFRESH_TOKEN.
# Realm base; /protocol/openid-connect/token is appended automatically.
# (Or set KEYCLOAK_TOKEN_URL directly to the full token endpoint instead.)
KEYCLOAK_ISSUER=https://keycloak.arifalidawood.com/realms/tenetx-mimic
KEYCLOAK_CLIENT_ID=tenetx-mimic-backend
KEYCLOAK_CLIENT_SECRET=

# --- GCP Workload Identity Federation (STS exchange target; no key file) ---
# WIF provider resource, prefixed //iam.googleapis.com/ -- must match the
# "wif-audience" custom-audience mapper configured on the Keycloak client.
GCP_WIF_AUDIENCE=//iam.googleapis.com/projects/59903512030/locations/global/workloadIdentityPools/keycloak-pool/providers/keycloak-oidc
# Target service account for impersonation after the STS exchange.
GCP_WIF_SERVICE_ACCOUNT_IMPERSONATION_URL=https://iamcredentials.googleapis.com/v1/projects/-/serviceAccounts/tenetx-mimic-firestore@tenetx-qa-scores.iam.gserviceaccount.com:generateAccessToken
# Optional -- both already default to these values in gcp_credentials.py;
# only set if overriding.
# GCP_WIF_STS_TOKEN_URL=https://sts.googleapis.com/v1/token
# GCP_WIF_SUBJECT_TOKEN_TYPE=urn:ietf:params:oauth:token-type:jwt
GCP_PROJECT_ID=tenetx-qa-scores
